# ===== Application =====
APP_NAME=my-backend
DEBUG=true
LOGGING_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ===== PostgreSQL =====
# asyncpg connection (для запросов)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydb
# SQLAlchemy connection (для миграций)
DATABASE_URL_SQLALCHEMY=postgresql+asyncpg://postgres:postgres@localhost:5432/mydb
DB_SCHEMA=public
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=20

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Security =====
# создание ENCRYPTION_KEY: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your-32-byte-secret-key-here
PRIVATE_KEY_PASSWORD=your-private-key-password

# ===== JWT Auth =====
# openssl genpkey -algorithm RSA -out keys/private.pem -aes256 -pass pass:твой_пароль_PRIVATE_KEY_PASSWORD
# openssl rsa -pubout -in keys/private.pem -out keys/public.pem -passin pass:твой_пароль_твой_пароль_PRIVATE_KEY_PASSWORD
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_LIFETIME=3600
REFRESH_TOKEN_LIFETIME=604800

# ===== S3 Storage =====
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=my-bucket
S3_PUBLIC_URL=https://my-bucket.s3.amazonaws.com
S3_REGION=us-east-1

# ===== RabbitMQ =====
RABBIT_AMQP=amqp://guest:guest@localhost:5672/

# ===== SMTP =====
SMTP_HOST=maildev
SMTP_PORT=1025
# true для продакшена
USE_TLS=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@example.com
